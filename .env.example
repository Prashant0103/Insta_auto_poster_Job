# ─────────────────────────────────────────────────────────────
# Pexels Configuration
# Get your free API key at https://www.pexels.com/api/
# ─────────────────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here
PEXELS_QUERY=nature,landscape,travel
PEXELS_PER_PAGE=20

# ─────────────────────────────────────────────────────────────
# Instagram Graph API Configuration
# IG_USER_ID    – numeric Instagram Business/Creator account ID
# IG_ACCESS_TOKEN – long-lived Page/System-User token with scopes:
#   instagram_basic, instagram_content_publish, pages_read_engagement
# ─────────────────────────────────────────────────────────────
IG_USER_ID=your_numeric_instagram_user_id
IG_ACCESS_TOKEN=your_long_lived_access_token_here

# ─────────────────────────────────────────────────────────────
# GitHub Gist State Sync (required for Render free-plan deploy)
# GITHUB_TOKEN  – Personal Access Token with 'gist' scope only
# STATE_GIST_ID – ID from gist URL: gist.github.com/<user>/<ID>
# Leave blank for local runs (state saves to POSTED_STATE_FILE)
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=
STATE_GIST_ID=

# ─────────────────────────────────────────────────────────────
# File Paths (relative to project root, or absolute)
# On Render set these to /var/data/... if using a paid disk
# ─────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
POSTED_STATE_FILE=posted_videos.json

# ─────────────────────────────────────────────────────────────
# Content Configuration
# ─────────────────────────────────────────────────────────────
CAPTION_THEME=inspirational
DEFAULT_HASHTAGS=#nature,#beautiful,#photography,#explore,#adventure
INSTAGRAM_MUSIC_QUERIES=

# ─────────────────────────────────────────────────────────────
# Posting Rules
# ─────────────────────────────────────────────────────────────
ALLOW_POST_WITHOUT_MUSIC=true
MAX_VIDEO_DURATION_SECONDS=60
MIN_ASPECT_RATIO=0.5
MAX_ASPECT_RATIO=2.0

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=
