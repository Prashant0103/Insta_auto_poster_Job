# ------------------------------------------------------------
# Video Source Selection
# Set a source to Y to make it primary. Sources set to N can still be used
# as fallbacks when their API keys are configured.
# ------------------------------------------------------------
PEXELS_YN=Y
YOUTUBE_YN=N

# ------------------------------------------------------------
# Pexels Configuration
# Get your free API key at https://www.pexels.com/api/
# ------------------------------------------------------------
PEXELS_API_KEY=your_pexels_api_key_here
PEXELS_QUERY=nature,landscape,travel
PEXELS_PER_PAGE=20

# ------------------------------------------------------------
# YouTube Configuration
# Requires a YouTube Data API v3 key.
# YOUTUBE_QUERY defaults to PEXELS_QUERY when blank.
# ------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_data_api_key_here
YOUTUBE_QUERY=viral shorts
YOUTUBE_MAX_RESULTS=8
YOUTUBE_MAX_DURATION_SECONDS=60
YOUTUBE_MIN_LIKE_COUNT=2000000
YOUTUBE_FORMAT=720

# ------------------------------------------------------------
# Jamendo Music Configuration
# Get a free client_id at: https://devportal.jamendo.com
# All Jamendo tracks are Creative Commons and free to use.
# ------------------------------------------------------------
JAMENDO_CLIENT_ID=your_jamendo_client_id_here
MUSIC_QUERY=ambient relaxing cinematic
MUSIC_VOLUME=0.8

# ------------------------------------------------------------
# Instagram Graph API Configuration
# IG_USER_ID: numeric Instagram Business/Creator account ID
# IG_ACCESS_TOKEN: long-lived Page/System-User token with scopes:
# instagram_basic, instagram_content_publish, pages_read_engagement
# ------------------------------------------------------------
IG_USER_ID=your_numeric_instagram_user_id
IG_ACCESS_TOKEN=your_long_lived_access_token_here

# ------------------------------------------------------------
# GitHub Gist State Sync
# GH_PAT: Personal Access Token with gist scope only
# STATE_GIST_ID: ID from gist URL: gist.github.com/<user>/<ID>
# Leave blank for local runs.
# ------------------------------------------------------------
GH_PAT=
STATE_GIST_ID=

# ------------------------------------------------------------
# File Paths
# Paths may be relative to project root or absolute.
# ------------------------------------------------------------
DOWNLOAD_DIR=downloads
POSTED_STATE_FILE=posted_videos.json

# ------------------------------------------------------------
# Content Configuration
# ------------------------------------------------------------
CAPTION_THEME=inspirational
DEFAULT_HASHTAGS=#nature,#beautiful,#photography,#explore,#adventure
INSTAGRAM_MUSIC_QUERIES=

# ------------------------------------------------------------
# Posting Rules
# ------------------------------------------------------------
ALLOW_POST_WITHOUT_MUSIC=true
MAX_VIDEO_DURATION_SECONDS=60
MIN_ASPECT_RATIO=0.5
MAX_ASPECT_RATIO=2.0

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=
