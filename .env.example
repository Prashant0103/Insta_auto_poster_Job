# Pexels Configuration
PEXELS_API_KEY=your_pexels_api_key_here
PEXELS_QUERY=nature,landscape,travel
PEXELS_PER_PAGE=20

# MCP Server Configuration
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Instagram Configuration
INSTAGRAM_LOGIN_URL=https://www.instagram.com/accounts/login/
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_USERNAME_SELECTOR=input[name="username"]
INSTAGRAM_PASSWORD_SELECTOR=input[name="password"]
INSTAGRAM_SUBMIT_SELECTOR=button[type="submit"]

# File Paths (relative to project root)
DOWNLOAD_DIR=downloads
POSTED_STATE_FILE=posted_videos.json

# Content Configuration
CAPTION_THEME=inspirational
DEFAULT_HASHTAGS=#nature,#beautiful,#photography,#explore,#adventure
INSTAGRAM_MUSIC_QUERIES=chill,ambient,nature sounds,relaxing

# Posting Configuration
ALLOW_POST_WITHOUT_MUSIC=true
MAX_VIDEO_DURATION_SECONDS=60
MIN_ASPECT_RATIO=0.5
MAX_ASPECT_RATIO=2.0

# Scheduling Configuration (for Windows Task Scheduler)
SCHEDULED_TASK_NAME=InstagramAutoPoster
DAILY_RUN_TIME=09:00

